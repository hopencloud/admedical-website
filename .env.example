# 이 파일은 "키 이름이 무엇인지" 알려주는 템플릿입니다.
# 실제 비밀키는 같은 폴더의 .env 파일에 적으세요.
# .env 파일은 .gitignore에 의해 GitHub에 올라가지 않습니다.

# === Supabase ===
# Supabase 프로젝트 대시보드 → Settings → API 메뉴에서 확인 가능
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...(긴 문자열)
SUPABASE_SERVICE_KEY=eyJhbG...(긴 문자열, service_role 키 — 절대 외부 노출 금지)

# === OpenAI ===
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-proj-...(긴 문자열)

# === 오류제보 메일 발송 (Vercel 환경변수에 설정, 로컬에는 불필요) ===
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx       # Gmail App Password 16자리 (띄어쓰기 제거)
# REPORT_TO_EMAIL=your_inbox@gmail.com   # 받는 메일이 다르면. 없으면 SMTP_USER로.
# ADMIN_PASSWORD=긴_랜덤_문자열       # 관리자 페이지 비밀번호
# PUBLIC_SITE_URL=https://my-domain.com  # 메일 본문 링크 (Vercel이 자동 추론하면 생략)
