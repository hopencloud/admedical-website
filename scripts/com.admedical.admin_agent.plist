<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  관리자 대시보드 Agent — 맥북 백그라운드 폴러.

  설치:
    cp scripts/com.admedical.admin_agent.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.admedical.admin_agent.plist

  중지:
    launchctl unload ~/Library/LaunchAgents/com.admedical.admin_agent.plist

  상태:
    launchctl list | grep com.admedical.admin_agent

  로그:
    tail -f ~/Library/Logs/admedical_admin_agent.log

    (또한 프로젝트 logs/admin_agent.log 에는 main 루프 자체의 추가 라인을 따로 안 남기지만,
     subprocess 가 daily_pipeline.sh 안에서 logs/daily_YYYYMMDD.log 를 작성한다.)
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.admedical.admin_agent</string>

    <!--
      bash 를 통해 실행. 이렇게 해야 macOS TCC 가 bash 의 Full Disk Access 권한을
      상속하여 ~/Downloads 와 ~/Desktop 등 보호 폴더 안에 있는 venv·SQLite·이미지에 접근 가능.
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>exec /Users/halim/Downloads/아카이브/admedical_website/venv/bin/python /Users/halim/Downloads/아카이브/admedical_website/scripts/admin_agent.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/halim/Downloads/아카이브/admedical_website</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!--
      stdout/stderr 는 Downloads 폴더 밖에 둠. launchd 의 xpcproxy 가 spawn 직전
      이 파일을 열어야 하는데, xpcproxy 는 Full Disk Access 가 없어서
      ~/Downloads 안에 두면 TCC 가 차단해 spawn 자체가 실패(exit 78).
      ~/Library/Logs/ 는 TCC 비제한.
    -->
    <key>StandardOutPath</key>
    <string>/Users/halim/Library/Logs/admedical_admin_agent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/halim/Library/Logs/admedical_admin_agent.log</string>
</dict>
</plist>
